ENVIRONMENT=development
STREAMLIT_API_BASE_URL=http://127.0.0.1:8000
MLFLOW_UI_URL=http://127.0.0.1:5000
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
HALLUCINATION_MODEL_NAME=cross-encoder/nli-deberta-v3-small
CHROMA_COLLECTION_NAME=rag_documents
CHROMA_PERSIST_DIRECTORY=data/chroma
UPLOADS_DIRECTORY=data/uploads
SQLITE_DB_PATH=data/rag_app.db
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=rag_production
CHUNK_SIZE=512
CHUNK_OVERLAP=64
DEFAULT_TOP_K=4
MAX_TOP_K=10
LLM_TEMPERATURE=0.1
REQUEST_TIMEOUT_SECONDS=60
HALLUCINATION_THRESHOLD=0.45
